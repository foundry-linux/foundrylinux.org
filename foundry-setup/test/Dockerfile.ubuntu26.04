# Test image for foundry-setup on Ubuntu 26.04 (target LTS)
# Usage:
#   docker build -f test/Dockerfile.ubuntu26.04 -t foundry-test:26.04 .
#   docker run --rm foundry-test:26.04 --dry-run
FROM ubuntu:26.04

RUN apt-get update -q && apt-get install -y --no-install-recommends \
        bash sudo curl ca-certificates lsb-release \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash -G sudo tester \
    && echo 'tester ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers
USER tester
WORKDIR /home/tester

# Copy the whole foundry-setup/ tree so install.sh can source lib.sh and
# dispatch to the per-metapackage scripts and source-wiring helpers.
COPY --chown=tester:tester . /home/tester/foundry-setup/
RUN chmod +x /home/tester/foundry-setup/*.sh

ENTRYPOINT ["bash", "/home/tester/foundry-setup/install.sh"]
CMD ["--help"]
