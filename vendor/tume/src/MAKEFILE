	mcopyrec.obj		\
	misc.obs		\
	mitems.obj		\
	msdos.obs		\
	msup.obs		\
	mwrtcrng.obj		\
	parallel.obj		\
	recorder.obs		\
	roomio.obs		\
	roomwin.obs		\
	rtsup.obs		\
	sparse.obf		\
	stackchk.obs		\
	tilebits.obs		\
	tiosup.obs		\
	tsetio.obs		\
	tumedraw.obf		\
	zpane.obs		\
	zerrors.obs		\
	stubs.obs		\

OVDEP = \
	menuitem.ovs		\
	ioini.ovs		\
	colorrei.ovs		\
	colorreq.ovs		\
	count.ovs		\
	download.ovs		\
	getname.ovs		\
