#!/usr/bin/make -f
# vgmstream's upstream CMakeLists has install() rules only inside `if(WIN32)`,
# so cmake's --install target is a no-op on Linux. We bypass dh_auto_install
# and copy the built binary into place manually.
#
# Plugins (Audacious, V123, etc.) are disabled — they have heavyweight
# runtime deps (libao, audacious-dev) we don't want to pull into the base
# decoder package.
#
# ATRAC9, CELT, and G.719 are disabled because their decoders live in
# ext_libs/ as Windows-only DLLs (.dll/.a); they can't be built on Linux.
# G.722.1 (Siren 14) is intentionally KEPT ON — it is compiled from plain
# C source in src/coding/libs/ (not a vendored binary), and the upstream
# ships it enabled by default. Disabling it would silently break decoding
# of files that use coding_G7221C.

export DEB_BUILD_MAINT_OPTIONS = hardening=+all

DEB_HOST_GNU_TYPE ?= $(shell dpkg-architecture -qDEB_HOST_GNU_TYPE)
BUILD_DIR = obj-$(DEB_HOST_GNU_TYPE)

%:
	dh $@

override_dh_autoreconf:
	# vgmstream has configure.ac but cmake is the supported Linux build —
	# skip autoreconf so debhelper doesn't try to regenerate autotools.

override_dh_auto_configure:
	dh_auto_configure --buildsystem=cmake -- \
	    -DCMAKE_BUILD_TYPE=Release \
	    -DBUILD_CLI=ON \
	    -DBUILD_V123=OFF \
	    -DBUILD_AUDACIOUS=OFF \
	    -DUSE_ATRAC9=OFF \
	    -DUSE_CELT=OFF \
	    -DUSE_G719=OFF \
	    -DUSE_FFMPEG=ON \
	    -DUSE_MPEG=ON \
	    -DUSE_VORBIS=ON \
	    -DUSE_SPEEX=ON

override_dh_auto_build:
	dh_auto_build --buildsystem=cmake

override_dh_auto_install:
	install -D -m 0755 $(BUILD_DIR)/cli/vgmstream-cli \
	    $(CURDIR)/debian/vgmstream/usr/bin/vgmstream-cli
