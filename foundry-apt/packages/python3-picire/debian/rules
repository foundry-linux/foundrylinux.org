#!/usr/bin/make -f
export DEB_BUILD_MAINT_OPTIONS = hardening=+all
export PYBUILD_NAME = picire
# Upstream uses setuptools_scm; building from a release sdist (not a git
# checkout) has no tags to read, so pin the version explicitly.
export SETUPTOOLS_SCM_PRETEND_VERSION = 21.8

%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_test:
	# upstream tests need pytest + fixtures; not required to ship the CLI
