#!/usr/bin/make -f
export DEB_BUILD_MAINT_OPTIONS = hardening=+all
export PYBUILD_NAME = inators
# Upstream uses setuptools_scm; building from a release sdist (not a git
# checkout) has no tags to read, so pin the version explicitly.
export SETUPTOOLS_SCM_PRETEND_VERSION = 2.1.1

%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_test:
	# upstream tests require pytest + tox; not needed to ship the library
