Description: add explicit X11/FLTK-platform includes for non-Windows builds
 main-window, modal-dialog and option-dialogs use fl_display, fl_xid,
 Pixmap and XA_CARDINAL under #ifndef _WIN32, but only <X11/xpm.h> was
 included. These resolve transitively on some FLTK 1.4 builds but not on
 FLTK 1.4.5's cleaned-up X11 headers. Add the includes to the shared
 utils.h so every translation unit that needs them gets them.
Author: Foundry Linux <packages@foundrylinux.org>
Forwarded: not-yet
Last-Update: 2026-06-10
--- a/src/utils.h
+++ b/src/utils.h
@@ -13,6 +13,11 @@
 
 #pragma warning(push, 0)
 #include <FL/fl_types.h>
+#ifndef _WIN32
+#include <FL/platform.H>
+#include <X11/Xlib.h>
+#include <X11/Xatom.h>
+#endif
 #pragma warning(pop)
 
 #ifdef _WIN32
