#!/bin/sh
set -e

# Undo the kicker-extra-favoritesrc diversion on final removal so Kubuntu's
# file is restored cleanly (no orphaned diversion).
if [ "$1" = "remove" ] || [ "$1" = "purge" ]; then
    dpkg-divert --remove --rename --package foundry-kde-theme \
        --divert /etc/xdg/kicker-extra-favoritesrc.kubuntu \
        /etc/xdg/kicker-extra-favoritesrc
    # Remove our postinst-created avatar, then undivert so Kubuntu's is restored.
    rm -f /etc/skel/.face
    dpkg-divert --remove --rename --package foundry-kde-theme \
        --divert /etc/skel/.face.kubuntu \
        /etc/skel/.face
fi

#DEBHELPER#
exit 0
