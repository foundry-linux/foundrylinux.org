#!/bin/sh
set -e

# Avatar: the divert-and-replace pattern (cf. dash diverting /bin/sh). preinst
# diverted Kubuntu's /etc/skel/.face gear; create the Foundry anvil here from
# the shipped avatar. The .face.icon symlink (kubuntu's, -> .face) resolves to it.
if [ "$1" = "configure" ] && [ -f /usr/share/foundry-linux/avatar.png ]; then
    cp /usr/share/foundry-linux/avatar.png /etc/skel/.face
fi

#DEBHELPER#
exit 0
