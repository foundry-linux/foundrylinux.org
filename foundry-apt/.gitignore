/dist/
/public/
/.aptly/
# dpkg-buildpackage artifacts that land outside dist/ when built locally
packages/**/.debhelper/
packages/**/debhelper-build-stamp
packages/**/files
packages/**/*.substvars
packages/**/*.buildinfo
packages/**/*.changes
# dpkg-buildpackage staging dir: debian/<pkgname>/ (generated, never authored).
# Negation patterns re-include the authored subdirs (man/, source/, patches/).
packages/**/debian/*/
!packages/**/debian/man/
!packages/**/debian/source/
!packages/**/debian/patches/
packages/**/*.deb
# dpkg-source artifacts (source packages) that land in packages/ root
packages/*.dsc
packages/*.tar.xz
packages/*.tar.gz
