# Test image for foundry-linux-setup on Ubuntu 24.04 (legacy LTS)
# Usage:
#   docker build -f test/Dockerfile.ubuntu24.04 -t foundry-test:24.04 .
#   docker run --rm foundry-test:24.04 --dry-run --allow-24.04
FROM ubuntu:24.04

# Minimum tooling to run the script + give sudo to a non-root user
RUN apt-get update -q && apt-get install -y --no-install-recommends \
        bash sudo curl ca-certificates lsb-release \
    && rm -rf /var/lib/apt/lists/*

# Non-root test user (mirrors how a real user would run the script)
RUN useradd -m -s /bin/bash -G sudo tester \
    && echo 'tester ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers
USER tester
WORKDIR /home/tester

COPY --chown=tester:tester install.sh /home/tester/install.sh
RUN chmod +x /home/tester/install.sh

ENTRYPOINT ["bash", "/home/tester/install.sh"]
CMD ["--help"]
